nextflow.enable.dsl=2

// create parameters (can be altered via command line)
params {
    bam_dir = null
    output_dir = null
    ref_dir = null
    haplotype_map = null
    metadata = null
    cpus = 1
    help = false
}

manifest {
    name = 'WESley-fingerprint'
    description = 'GATK Picard fingerprinting to verify sample identity'
    nextflowVersion = '>=25.04.6'
    author = 'Dien Ethan Mach'
    mainScript = 'fingerprint.nf'
    homePage = 'https://github.com/e10m/WESley'
}

process {
    container = 'broadinstitute/picard:3.4.0'
    containerOptions = "-v ${params.ref_dir}:/references"
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'retry' : (task.attempt <= 2 ? 'retry' : 'ignore') }
    maxRetries    = 5
    maxErrors     = '-1'

    // CPU labels (static - CPUs don't scale with retries)
    withLabel: 'highCpu' { cpus = params.cpus }
    withLabel: 'medCpu' { cpus = 8 }
    withLabel: 'lowCpu' { cpus = 1 }

    // Memory labels (dynamic - linear per retry)
    withLabel: 'extraHighMem' { memory = { 64.GB * task.attempt } }
    withLabel: 'highMem'      { memory = { 40.GB * task.attempt } }
    withLabel: 'medMem'       { memory = { 12.GB * task.attempt } }
    withLabel: 'lowMem'       { memory = { 1.GB  * task.attempt } }

    // Time labels (dynamic - linear per retry)
    withLabel: 'longTime'  { time = { 48.h * task.attempt } }
    withLabel: 'medTime'   { time = { 24.h * task.attempt } }
    withLabel: 'shortTime' { time = { 8.h  * task.attempt } }
}

// Profiles for different execution environments
profiles {
    local {
        process.executor = 'local'
    }
}

docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g)'
}
