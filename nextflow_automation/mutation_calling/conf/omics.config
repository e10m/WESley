/*
========================================================================================
    AWS HealthOmics Configuration
========================================================================================
    Loaded conditionally when $AWS_WORKFLOW_RUN is set.
    Overrides container images (ECR), publishDir, resource settings,
    and reference file paths for S3.
========================================================================================
*/

// -- Reference files from S3 (override these via --params-file or input JSON) --
params {
    ref_dir                 = "s3://omics-sequence-971422717605-4-8-2026/references/"
    
    // S3 reference paths — set these per-run or via parameter template
    ref_fasta               = "s3://omics-sequence-971422717605-4-8-2026/references/Homo_sapiens_assembly38.fasta"
    ref_fasta_index         = "s3://omics-sequence-971422717605-4-8-2026/references/Homo_sapiens_assembly38.fasta.fai"
    ref_dict                = "s3://omics-sequence-971422717605-4-8-2026/references/Homo_sapiens_assembly38.dict"
    gnomad_vcf              = "s3://omics-sequence-971422717605-4-8-2026/references/af-only-gnomad.hg38.vcf.gz"
    gnomad_vcf_index        = "s3://omics-sequence-971422717605-4-8-2026/references/af-only-gnomad.hg38.vcf.gz.tbi"
    contamination_vcf       = "s3://omics-sequence-971422717605-4-8-2026/references/small_exac_common_3.hg38.vcf.gz"
    contamination_vcf_index = "s3://omics-sequence-971422717605-4-8-2026/references/small_exac_common_3.hg38.vcf.gz.tbi"
    muse_dbsnp              = "s3://omics-sequence-971422717605-4-8-2026/references/common_all_20180418.vcf.gz"
    nonsynonymous_list      = "s3://omics-sequence-971422717605-4-8-2026/references/nonsynonymous.txt"
    vep_cache               = "s3://annotation-cache/vep_cache/115_GRCh38/"
    interval_list           = null  // e.g., "s3://bucket/references/interval_list.bed"

    // Secrets Manager for OncoKB
    use_secrets_manager = true
    oncokb_secret_name  = "oncokb-api-key"

    // Output directory for HealthOmics
    output_dir = "/mnt/workflow/pubdir"
}

// -- Process overrides --
process {
    // Remove local-only directives
    containerOptions = ''

    // -- ECR container images --
    // Replace <ACCOUNT_ID> and <REGION> with your AWS account and region
    withName: 'MUTECT2_CALL|GET_PILEUP_SUMMARIES|CALCULATE_CONTAMINATION|LEARN_READ_ORIENTATION|FILTER_MUTECT_CALLS|MERGE_VCFS|SELECT_VARIANTS' {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/gatk:4.2.0.0'
    }
    withName: 'MUTECT2_PON|GENOMICS_DB_IMPORT|CREATE_PON' {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/gatk:4.2.0.0'
    }
    withName: 'PILEUP|INDEX' {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/samtools:1.10'
    }
    withName: MUSE {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/muse:1.0.rc'
    }
    withName: VARSCAN2 {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/varscan2:latest'
    }
    withName: VEP {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/vep:115.0'
    }
    withName: REHEADER {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/bcftools:1.10.2'
    }
    withName: CREATE_MAF {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/vcf2maf:1.6.19'
    }
    withName: 'KEEP_NONSYNONYMOUS|RENAME_HG38|KEEP_TERTP' {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/ubuntu:20.04'
    }
    withName: ONCOKB {
        container = '971422717605.dkr.ecr.us-west-2.amazonaws.com/oncokb:3.0.0'
    }
}

// -- Disable local Docker options --
docker {
    runOptions = ''
}
