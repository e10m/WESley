nextflow.enable.dsl=2

// create parameters (can be altered via command line)
params {
    output_dir = null
    ref_dir = null
    metadata = null
    cpus = 30
    interval_list = null
    normal_dir = null

    // optional parameters
    help = false
    test_mode = false

    // reference file paths (defaults for local mode; /references is mounted via containerOptions)
    ref_fasta = "/references/Homo_sapiens_assembly38.fasta"
    ref_fasta_index = "/references/Homo_sapiens_assembly38.fasta.fai"
    ref_dict = "/references/Homo_sapiens_assembly38.dict"
    gnomad_vcf = "/references/af-only-gnomad.hg38.vcf.gz"
    gnomad_vcf_index = "/references/af-only-gnomad.hg38.vcf.gz.tbi"
    contamination_vcf = "/references/small_exac_common_3.hg38.vcf.gz"
    contamination_vcf_index = "/references/small_exac_common_3.hg38.vcf.gz.tbi"
    muse_dbsnp = "/references/common_all_20180418.vcf.gz"
    nonsynonymous_list = "/references/nonsynonymous.txt"
    vep_cache = "/opt/vep/.vep"

    // OncoKB settings
    use_secrets_manager = false
    oncokb_api_key = null
    oncokb_secret_name = "oncokb-api-key"
}

manifest {
    name = 'WESley-mutation-calling'
    description = 'Somatic variant calling using up to 3 variant callers (Mutect2, MuSE, Varscan2)'
    nextflowVersion = '>=25.04.6'
    author = 'Dien Ethan Mach'
    mainScript = 'mutation_calling.nf'
    homePage = 'https://github.com/e10m/WESley'
}

process {
    executor = 'local'
    containerOptions = { params.ref_dir ? "-v ${params.ref_dir}:/references" : "" }
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'retry' : (task.attempt <= 2 ? 'retry' : 'ignore') }
    maxRetries    = 5
    maxErrors     = -1

    // CPU labels (static - CPUs don't scale with retries)
    withLabel: 'highCpu' { cpus = params.cpus }
    withLabel: 'medCpu' { cpus = 4 }
    withLabel: 'lowCpu' { cpus = 1 }

    // Memory labels (dynamic - double per retry)
    withLabel: 'extraHighMem' { memory = { 64.GB * task.attempt } }
    withLabel: 'highMem' { memory = { 40.GB * task.attempt } }
    withLabel: 'medMem' { memory = { 12.GB * task.attempt } }
    withLabel: 'lowMem' { memory = { 1.GB * task.attempt } }

    // Time labels (dynamic - double per retry)
    // Note: Mutation calling uses longer time limits than data processing
    withLabel: 'longTime' { time = { 32.h * task.attempt } }
    withLabel: 'medTime' { time = { 16.h * task.attempt } }
    withLabel: 'shortTime' { time = { 8.h * task.attempt } }
    withLabel: 'extraLongTime' { time = { 48.h * task.attempt } }

    withName: PILEUP {
        container = 'quay.io/biocontainers/samtools:1.10--h9402c20_1'
    }

    withName: 'MUTECT2_CALL|GET_PILEUP_SUMMARIES|CALCULATE_CONTAMINATION|LEARN_READ_ORIENTATION|FILTER_MUTECT_CALLS|MERGE_VCFS|SELECT_VARIANTS' {
        container = 'broadinstitute/gatk:4.2.0.0'
    }

    withName: MUSE {
        container = 'quay.io/biocontainers/muse:1.0.rc--1'
    }
    withName: VARSCAN2 {
        container = 'e10m/varscan2:latest'
    }
    withName: INDEX {
        container = 'quay.io/biocontainers/samtools:1.10--h9402c20_1'
    }
    withName: VEP {
        container = 'ensemblorg/ensembl-vep:release_115.0'
    }
    withName: REHEADER {
        container = 'staphb/bcftools:1.10.2'
    }
    withName: CREATE_MAF {
        container = 'e10m/vcf2maf:1.6.19'
    }
    withName: 'KEEP_NONSYNONYMOUS|RENAME_HG38|KEEP_TERTP' {
        container = 'ubuntu:20.04'
    }
    withName: ONCOKB {
        container = 'e10m/oncokb:3.0.0'
    }
}

docker {
    enabled = true
    runOptions = '--user $(id -u):$(id -g)'
}

// Load HealthOmics overrides when running on AWS HealthOmics
if (System.getenv('AWS_WORKFLOW_RUN')) {
    includeConfig 'conf/omics.config'
}
