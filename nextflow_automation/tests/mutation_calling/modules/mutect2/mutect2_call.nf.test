nextflow_process {
    name "Test Process MUTECT2_CALL"
    script "../../../../mutation_calling/modules/mutect2/mutect2_call.nf"
    process "MUTECT2_CALL"
    config "../../../shared-test.config"

    test("Should run paired calling without failures") {

        when {
            params {
                load("$baseDir/tests/test-params.yaml")
                }
            process {
                """
                input[0] = [
                    'test',
                    'testT',
                    file('${params.test_data}/bams/chr22/test2.paired_end.sorted.bam'),
                    file('${params.test_data}/bams/chr22/test2.paired_end.sorted.bam.bai'),
                    [],
                    'testN',
                    file('${params.test_data}/bams/chr22/test.paired_end.sorted.bam'),
                    file('${params.test_data}/bams/chr22/test.paired_end.sorted.bam.bai'),
                ]
                input[1] = file(params.ref_fasta)
                input[2] = file(params.ref_fasta_index)
                input[3] = file(params.ref_dict)
                input[4] = file(params.gnomad_vcf)
                input[5] = file(params.gnomad_vcf_index)
                input[6] = file(params.interval_list)
                """
            }
        }

        then {
            assert process.success
            assert process.out.size() > 0
            assert snapshot(process.out).match()
        }
    }

    test("Should run tumor-only mode without failing") {

        when {
            params {
                load("$baseDir/tests/test-params.yaml")
            }
            process {
                """
                input[0] = [
                    'test',
                    'testT',
                    file('${params.test_data}/bams/chr22/test2.paired_end.sorted.bam'),
                    file('${params.test_data}/bams/chr22/test2.paired_end.sorted.bam.bai'),
                    [],
                    'testN',
                    [],
                    []
                ]
                input[1] = file(params.ref_fasta)
                input[2] = file(params.ref_fasta_index)
                input[3] = file(params.ref_dict)
                input[4] = file(params.gnomad_vcf)
                input[5] = file(params.gnomad_vcf_index)
                input[6] = file(params.interval_list)
                """
            }
        }

        then {
            assert process.success
            assert process.out.size() > 0
            assert snapshot(process.out).match()
        }
    }
}
