nextflow_process {

    name "Test Process FASTQC"
    script "../../../data_processing/modules/fastqc.nf"
    process "FASTQC"
    config "../../shared-test.config"

    test("Should run FASTQC checks without failures") {
        when {
            params {
                load("$baseDir/tests/test-params.yaml")
            }
            process {
                // required inputs for test data
                """
                input[0] = [
                    'dummy',
                    'L001',
                    file("${params.test_data}/fastqs/dummy_t_R1_xxx.fastq.gz", checkIfExists: true),
                    file("${params.test_data}/fastqs/dummy_t_R2_xxx.fastq.gz", checkIfExists: true),
                    'illumina_novaseq_x',
                    'tcgb',
                    false
                ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.size() > 0
            assert snapshot(process.out).match()
        }
    }
}
