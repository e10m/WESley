nextflow_process {

    name "Test Process TRIM"
    script "../../../data_processing/modules/trim_adapters.nf"
    process "TRIM"
    config "../../shared-test.config"


    test("Should trim FASTQs without failures") {

        when {
            params{
                test_data = "${projectDir}/test-data"
                ref_dir = "${params.test_data}/references"
                test_mode = true
            }
            process {
                """
                input[0] = [
                    'dummy',
                    'L001',
                    file("${params.test_data}/fastqs/dummy_t_R1_xxx.fastq.gz", checkIfExists: true),
                    file("${params.test_data}/fastqs/dummy_t_R2_xxx.fastq.gz", checkIfExists: true),
                    'illumina_novaseq_x',
                    'tcgb',
                    false
                ]
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }
}